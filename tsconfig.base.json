{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@chengxiaobang/shared": ["packages/shared/src/index.ts"],
      "@chengxiaobang/shared/error": ["packages/shared/src/error.ts"],
      "@chengxiaobang/shared/product": ["packages/shared/src/product.ts"],
      "@chengxiaobang/backend/*": ["apps/backend/src/*"],
      "@chengxiaobang/desktop/*": ["apps/desktop/src/*"]
    }
  }
}
