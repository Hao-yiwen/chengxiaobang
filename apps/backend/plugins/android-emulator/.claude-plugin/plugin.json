{
  "name": "android-emulator",
  "version": "0.1.0",
  "description": "为程小帮提供 Android 开发工作流和模拟器自动化能力。",
  "author": { "name": "Z.ai" },
  "license": "MIT",
  "skills": "skills",
  "commands": "commands",
  "mcpServers": {
    "android-emulator": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/dist/mcp/server.js"],
      "cwd": "${CLAUDE_PROJECT_DIR}",
      "env": {
        "ANDROID_PLUGIN_DATA": "${CLAUDE_PLUGIN_DATA}",
        "ANDROID_PLUGIN_SDK_PATH": "${user_config.sdk_path}",
        "ANDROID_PLUGIN_DEFAULT_AVD": "${user_config.default_avd}",
        "ANDROID_PLUGIN_API_LEVEL": "${user_config.api_level}",
        "ANDROID_PLUGIN_BUILD_TOOLS_VERSION": "${user_config.build_tools_version}",
        "ANDROID_PLUGIN_SYSTEM_IMAGE_VARIANT": "${user_config.system_image_variant}",
        "ANDROID_PLUGIN_SYSTEM_IMAGE_ABI": "${user_config.system_image_abi}",
        "ANDROID_PLUGIN_JDK_MAJOR": "${user_config.jdk_major}"
      }
    }
  },
  "userConfig": {
    "sdk_path": {
      "type": "string",
      "default": "",
      "description": "可选的 Android SDK 根目录。为空时会回退到 ANDROID_HOME、ANDROID_SDK_ROOT 或常见系统路径。"
    },
    "default_avd": {
      "type": "string",
      "default": "medium_phone",
      "description": "首选 AVD 或设备名称。"
    },
    "api_level": {
      "type": "string",
      "default": "35",
      "description": "生成项目、安装 SDK 包和默认系统镜像时使用的 Android API 级别。"
    },
    "build_tools_version": {
      "type": "string",
      "default": "35.0.0",
      "description": "安装指引使用的 Android SDK build-tools 版本。"
    },
    "system_image_variant": {
      "type": "string",
      "default": "default",
      "description": "Android 系统镜像类型：default、google_apis 或 google_apis_playstore。"
    },
    "system_image_abi": {
      "type": "string",
      "default": "",
      "description": "可选的 Android 系统镜像 ABI 覆盖值。为空时 Apple Silicon/ARM64 主机使用 arm64-v8a，其它主机使用 x86_64。"
    },
    "jdk_major": {
      "type": "string",
      "default": "17",
      "description": "预检和安装指引使用的 JDK 主版本。"
    }
  }
}
