{
  "name": "ios-simulator",
  "version": "0.1.0",
  "description": "为程小帮提供 iOS 开发工作流和模拟器自动化能力。",
  "author": { "name": "Z.ai" },
  "license": "MIT",
  "skills": "skills",
  "commands": "commands",
  "mcpServers": {
    "ios-simulator": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/dist/mcp/server.js"],
      "cwd": "${CLAUDE_PROJECT_DIR}",
      "env": {
        "IOS_SIM_PACKAGE_ROOT": "${CLAUDE_PLUGIN_ROOT}",
        "IOS_SIM_PLUGIN_DATA": "${CLAUDE_PLUGIN_DATA}",
        "IOS_SIM_DEFAULT_DEVICE": "${user_config.default_device}",
        "IOS_SIM_UI_BACKEND": "${user_config.ui_backend}"
      }
    }
  },
  "userConfig": {
    "default_device": {
      "type": "string",
      "default": "iPhone 16",
      "description": "首选模拟器设备名称。"
    },
    "ui_backend": {
      "type": "string",
      "default": "auto",
      "description": "UI 交互后端：auto、idb、xcodebuildmcp 或 none。"
    }
  }
}
