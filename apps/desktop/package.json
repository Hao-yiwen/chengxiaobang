{
  "name": "@chengxiaobang/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "程小帮 macOS desktop app.",
  "author": "chengxiaobang",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:vite": "vite --host 127.0.0.1",
    "icons": "tsx scripts/generate-icons.ts",
    "ocr:download": "node scripts/download-ocr-models.mjs",
    "build": "node scripts/clean-dist.mjs && pnpm run icons && tsup --config tsup.config.ts && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "package:mac": "pnpm run build && electron-builder --mac"
  },
  "dependencies": {
    "@aiden0z/pptx-renderer": "1.1.0",
    "@chengxiaobang/shared": "workspace:*",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@napi-rs/canvas": "^1.0.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-accessible-icon": "^1.1.9",
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-alert-dialog": "1.1.16",
    "@radix-ui/react-aspect-ratio": "^1.1.9",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-collapsible": "^1.1.13",
    "@radix-ui/react-context-menu": "^2.3.0",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-form": "^0.1.9",
    "@radix-ui/react-hover-card": "^1.1.16",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-menubar": "^1.1.17",
    "@radix-ui/react-navigation-menu": "^1.2.15",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-radio-group": "^1.4.0",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slider": "^1.4.0",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-toast": "^1.2.16",
    "@radix-ui/react-toggle": "^1.1.11",
    "@radix-ui/react-toggle-group": "^1.1.12",
    "@radix-ui/react-toolbar": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@radix-ui/react-visually-hidden": "^1.2.5",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron-updater": "6.8.9",
    "i18next": "^26.3.1",
    "jszip": "^3.10.1",
    "katex": "^0.17.0",
    "mammoth": "^1.12.0",
    "node-pty": "1.1.0",
    "onnxruntime-node": "^1.26.0",
    "pdfjs-dist": "5.4.624",
    "pino": "^10.3.1",
    "ppu-paddle-ocr": "^5.8.3",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-i18next": "^17.0.8",
    "remark-breaks": "^4.0.0",
    "sharp": "0.34.5",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^2.6.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "electron": "39.2.6",
    "electron-builder": "24.13.3",
    "tailwindcss-animate": "^1.0.7"
  },
  "build": {
    "appId": "com.chengxiaobang.desktop",
    "productName": "程小帮",
    "directories": {
      "output": "out"
    },
    "artifactName": "chengxiaobang-${version}-${os}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/@napi-rs/canvas/**",
      "node_modules/@napi-rs/canvas-*/**",
      "node_modules/node-pty/**",
      "node_modules/onnxruntime-node/**",
      "node_modules/sharp/**",
      "node_modules/@img/**"
    ],
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend"
      },
      {
        "from": "../../node_modules/.pnpm/bun@1.3.14/node_modules/bun/bin/bun.exe",
        "to": "bun"
      },
      {
        "from": "assets/ocr",
        "to": "ocr"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Hao-yiwen",
        "repo": "chengxiaobang"
      }
    ]
  }
}
