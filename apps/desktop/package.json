{
  "name": "@chengxiaobang/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "程小帮 macOS desktop app.",
  "author": "chengxiaobang",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:vite": "vite --host 127.0.0.1",
    "icons": "tsx scripts/generate-icons.ts",
    "build": "node scripts/clean-dist.mjs && pnpm run icons && tsup --config tsup.config.ts && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "package:mac": "pnpm run build && electron-builder --mac"
  },
  "dependencies": {
    "@chengxiaobang/shared": "workspace:*",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tooltip": "^1.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "i18next": "^26.3.1",
    "lucide-react": "0.556.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-i18next": "^17.0.8",
    "tailwind-merge": "^2.6.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "electron": "39.2.6",
    "electron-builder": "24.13.3",
    "sharp": "0.34.5",
    "tailwindcss-animate": "^1.0.7"
  },
  "build": {
    "appId": "com.chengxiaobang.desktop",
    "productName": "程小帮",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend"
      },
      {
        "from": "../../node_modules/.pnpm/bun@1.3.14/node_modules/bun/bin/bun.exe",
        "to": "bun"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
