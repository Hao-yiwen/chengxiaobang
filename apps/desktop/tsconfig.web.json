{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "baseUrl": ".",
    "rootDir": "../..",
    "ignoreDeprecations": "5.0",
    "paths": {
      "@/*": ["src/renderer/*"],
      "@chengxiaobang/shared": ["../../packages/shared/src/index.ts"]
    },
    "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom"]
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/renderer/**/*.tsx",
    "src/renderer/**/*.d.ts",
    "test/stream-client.test.ts",
    "test/app.test.tsx"
  ]
}
