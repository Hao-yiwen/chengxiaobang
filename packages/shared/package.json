{
  "name": "@chengxiaobang/shared",
  "version": "0.1.14",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./error": {
      "types": "./dist/error.d.ts",
      "import": "./dist/error.js"
    },
    "./product": {
      "types": "./dist/product.d.ts",
      "import": "./dist/product.js"
    }
  },
  "scripts": {
    "catalog:generate": "node scripts/generate-provider-catalog.mjs --write",
    "catalog:check": "node scripts/generate-provider-catalog.mjs --check",
    "build": "pnpm run catalog:check && tsup src/index.ts src/error.ts src/product.ts --format esm --dts --out-dir dist",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "zod": "4.2.0"
  },
  "devDependencies": {
    "js-yaml": "4.1.0"
  }
}
