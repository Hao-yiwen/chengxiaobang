{
  "name": "chengxiaobang",
  "version": "0.1.12",
  "private": true,
  "description": "程小帮 Electron AI assistant desktop app.",
  "packageManager": "pnpm@11.0.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @chengxiaobang/desktop dev",
    "typecheck": "pnpm --filter @chengxiaobang/shared build && pnpm -r typecheck",
    "test": "vitest run --config vitest.config.ts",
    "build": "pnpm --filter @chengxiaobang/shared build && pnpm --filter @chengxiaobang/backend build && pnpm --filter @chengxiaobang/desktop build",
    "package:mac": "pnpm run build && pnpm --filter @chengxiaobang/desktop exec electron-builder --mac",
    "package:win": "pnpm run build && pnpm --filter @chengxiaobang/desktop exec electron-builder --win --x64"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.10.2",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "@vscode/ripgrep": "^1.18.0",
    "autoprefixer": "10.4.22",
    "bun": "1.3.14",
    "jsdom": "27.2.0",
    "postcss": "8.5.6",
    "tailwindcss": "3.4.17",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "7.2.6",
    "vitest": "4.0.15"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@napi-rs/canvas",
      "@google/genai",
      "bun",
      "electron",
      "esbuild",
      "node-pty",
      "onnxruntime-node",
      "ppu-paddle-ocr",
      "protobufjs",
      "sharp"
    ]
  }
}
